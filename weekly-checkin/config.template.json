{
  "smartlead_api_key": "YOUR_SMARTLEAD_API_KEY",
  "google_sheet_id": "YOUR_MASTER_TRACKER_SHEET_ID",

  "google_oauth": {
    "credentials_file": "credentials.json",
    "token_file": "token.json"
  },

  "clients": [
    {
      "name": "Acme Co",
      "rep_tabs": ["Alice Rep", "Bob Rep"],
      "smartlead_campaign_ids": [123456, 234567]
    },
    {
      "name": "Beta Inc",
      "rep_tabs": ["Carol Rep"],
      "smartlead_campaign_ids": [345678]
    }
  ],

  "schedule": {
    "cron": "0 9 * * 1"
  },

  "delivery": {
    "type": "google_doc",
    "target": "YOUR_GOOGLE_DOC_ID",

    "slack_webhook_env": "WEEKLY_CHECKIN_SLACK_WEBHOOK",

    "from_address": "reports@youragency.com",
    "subject": "Weekly client check-in",
    "smtp_host": "smtp.gmail.com",
    "smtp_port": 587,
    "smtp_user": "reports@youragency.com",
    "smtp_password_env": "WEEKLY_CHECKIN_SMTP_PASSWORD"
  }
}
