# List Builder — API keys
# Copy this file to .env and fill in what you have.
# Only APOLLO_API_KEY is required. Everything else is optional.

# Apollo (required)
APOLLO_API_KEY=

# Per-client Apollo keys (optional — use if you have separate keys per client)
# APOLLO_API_KEY_ACME=

# Email validation waterfall (optional but recommended before loading into sequences)
# Add at least one. The pipeline uses whatever keys are present, cheapest first.
MILLIONVERIFIER_API_KEY=
ZEROBOUNCE_API_KEY=
PROSPEO_API_KEY=
LEADMAGIC_API_KEY=

# Phone validation — line type check (mobile / landline / voip) via Twilio Lookup
# Optional. Without this, phones are included but marked UNVERIFIED.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
