{
  "apollo_api_key": "YOUR_APOLLO_API_KEY",
  "google_sheet_id": "YOUR_GOOGLE_SHEET_ID",

  "reps": {
    "Alice Rep": { "apollo_user_id": "APOLLO_USER_ID_FOR_ALICE" },
    "Bob Rep": { "apollo_user_id": "APOLLO_USER_ID_FOR_BOB" }
  },

  "keep_dispositions": ["Interested", "Meeting Booked", "Not Interested"],
  "keep_prefixes": ["Callback"],

  "backfill_days": 30,

  "manual_columns": ["ICP", "Notes", "Next Step", "Deck Link"],

  "stats": {
    "summary_tab": "Overall Statistics",
    "icp_column": "ICP",
    "meeting_dispositions": ["Meeting Booked"],
    "qualified_dispositions": ["Interested", "Meeting Booked", "Not Interested"],
    "leaderboard_metric": "rate",
    "labels": {
      "icp_header": "ICP Breakdown",
      "icp_category_col": "ICP",
      "icp_count_col": "Count",
      "trends_header": "Meeting Trends",
      "trends_week_col": "Week",
      "trends_count_col": "Meetings",
      "rates_header": "Conversion Rates",
      "rates_rep_col": "Rep",
      "rates_conversations_col": "Conversations",
      "rates_qualified_col": "Qualified Conversations",
      "rates_meetings_col": "Meetings",
      "rates_meeting_rate_col": "Meeting Rate",
      "rates_conversion_rate_col": "Conversion Rate",
      "rates_overall_row": "Overall",
      "leaderboard_header": "Rep Leaderboard",
      "leaderboard_rep_col": "Rep",
      "leaderboard_metric_col": "Conv. Rate"
    }
  },

  "recording_source": {
    "_comment": "Which dialer the Recording URL column is resolved from. type must be one of: apollo, trellus, manual-url. Remove this whole block (or set type to \"\") to leave the Recording URL column blank. apollo: use the recording_url Apollo's API attaches to each call. trellus: parse the Trellus session id (a sess_ token) out of the call note and build the link; optional base_url overrides the Trellus recording-URL base. manual-url: use a recording URL you attach per call by hand; optional field overrides the call key the URL lives on (default manual_recording_url).",
    "type": "apollo"
  },

  "google_oauth": {
    "credentials_file": "credentials.json",
    "token_file": "token.json"
  },

  "state_file": "state.json"
}
